{
  "name": "wicom-move",
  "version": "0.1.0",
  "private": true,
  "description": "Cổng vận động gây quỹ nội bộ Wicom — Lark SSO + Strava sync",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "postinstall": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "strava:webhook": "tsx scripts/strava-webhook.ts",
    "strava:history": "tsx scripts/backfill-all-history.ts",
    "seed:demo": "tsx scripts/seed-demo.ts",
    "clear:demo": "tsx scripts/clear-demo.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.2.1",
    "jose": "^5.9.6",
    "leaflet": "^1.9.4",
    "next": "^15.1.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.14",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.2",
    "prisma": "^6.2.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
