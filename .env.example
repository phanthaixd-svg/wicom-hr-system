# ============================================================
#  Wicom Move — biến môi trường (COPY sang .env, KHÔNG commit .env)
# ============================================================

# --- App ---
# URL gốc của app khi deploy (Strava/Lark redirect về đây). Bắt buộc HTTPS ở production.
# Staging: https://abc.vercel.app   |   Production: https://congty.com
APP_BASE_URL="https://move.wicom.vn"
# Chuỗi bí mật ký session cookie (tạo bằng: openssl rand -base64 32). MỖI môi trường 1 chuỗi RIÊNG.
SESSION_SECRET="thay-bang-chuoi-ngau-nhien-that-dai"
# NODE_ENV=production ở prod (cookie secure + tối ưu). Host thường tự set khi build/run.
NODE_ENV="production"

# --- Admin bootstrap ---
# Email (phân tách bằng dấu phẩy) sẽ TỰ được cấp quyền admin khi đăng nhập Lark — mồi admin đầu tiên trên DB sạch.
# Chỉ NÂNG lên admin, không tự hạ quyền. Để trống = không ai tự thành admin (cấp tay trong Console).
ADMIN_EMAILS="thaiphan@wicom.asia"

# --- Database (PostgreSQL) ---
DATABASE_URL="postgresql://user:password@localhost:5432/wicom_move?schema=public"

# --- Lark / Larksuite OAuth ---
# Lấy trong Lark Developer Console → App của Wicom.
# Lưu ý vùng: quốc tế = larksuite.com, Trung Quốc = feishu.cn (đổi LARK_BASE_* bên dưới).
LARK_CLIENT_ID="cli_xxxxxxxxxxxx"
LARK_CLIENT_SECRET="xxxxxxxxxxxxxxxxxxxxxxxx"
# Giới hạn đăng nhập trong đúng tenant Wicom (điền Tenant Key của Wicom nếu muốn siết).
LARK_TENANT_KEY=""
# Endpoint (mặc định cho Larksuite quốc tế — kiểm tra lại trong Console nếu dùng Feishu):
LARK_AUTHORIZE_URL="https://accounts.larksuite.com/open-apis/authen/v1/authorize"
LARK_TOKEN_URL="https://passport.larksuite.com/suite/passport/oauth/token"
LARK_USERINFO_URL="https://passport.larksuite.com/suite/passport/oauth/userinfo"
# API base để BOT gửi tin (tenant token): quốc tế = open.larksuite.com, Feishu = open.feishu.cn
LARK_API_BASE="https://open.larksuite.com"
# 🔴 Bật/tắt BOT nhắn Lark thật. STAGING nên đặt "false" để test không DM thật cho nhân viên. PROD = để trống/true.
LARK_NOTIFY_ENABLED="false"

# --- Strava OAuth + Webhook ---
# Lấy trong https://www.strava.com/settings/api
STRAVA_CLIENT_ID="123456"
STRAVA_CLIENT_SECRET="xxxxxxxxxxxxxxxxxxxxxxxx"
# Chuỗi tự đặt, dùng khi Strava xác thực webhook callback:
STRAVA_WEBHOOK_VERIFY_TOKEN="wicom-move-verify-token"

# --- Quy đổi tiền ---
# Chỉ quy đổi TIỀN cho hoạt động từ ngày này trở đi (YYYY-MM-DD).
# Hoạt động trước mốc: tiền = 0 nhưng vẫn hiện trong leaderboard km/số hoạt động.
# Để trống = quy đổi mọi hoạt động. (Campaign.conversionFromDate trong DB được ưu tiên hơn biến này.)
CONVERSION_FROM_DATE="2026-03-01"

# --- Cron backfill ---
# Bí mật để bảo vệ endpoint /api/cron/backfill (đặt header Authorization: Bearer <giá trị này>)
CRON_SECRET="thay-bang-chuoi-bi-mat"
